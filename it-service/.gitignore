# === Secrets & credentials (safety net — this repo should never contain these) ===
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
credentials
secrets.*

# === Terraform state (may contain credentials / resource identifiers) ===
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
.terraform/
.terraform.lock.hcl

# === Python ===
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.mypy_cache/

# === OS / Editor ===
.DS_Store
.idea/
*.log
